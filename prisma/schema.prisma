// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

enum CompetitorLegalStatus {
  PENDING
  APPROVED
  BLOCKED
}

enum RenderMode {
  HTTP
  BROWSER
}

enum ProductMatchStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum PriceExtractionMethod {
  JSON_LD
  META
  CSS
  FALLBACK
}

enum ScrapeRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum ScrapeTrigger {
  MANUAL
  CRON
}

model ShopifyProduct {
  id             String   @id @default(cuid())
  shopifyId      String   @unique
  title          String
  vendor         String?
  handle         String
  productType    String?
  categoryName   String?
  onlineStoreUrl String?
  status         String
  syncedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  variants ShopifyVariant[]

  @@index([vendor])
  @@index([status])
}

model ShopifyVariant {
  id              String   @id @default(cuid())
  shopifyId       String   @unique
  productId       String
  title           String
  sku             String?
  barcode         String?
  price           Decimal  @db.Decimal(12, 2)
  currencyCode    String   @default("EUR") @db.VarChar(3)
  selectedOptions Json?
  active          Boolean  @default(true)
  syncedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product ShopifyProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  matches ProductMatch[]

  @@index([productId])
  @@index([sku])
}

model Competitor {
  id                   String                @id @default(cuid())
  name                 String                @unique
  domain               String                @unique
  active               Boolean               @default(true)
  legalStatus          CompetitorLegalStatus @default(PENDING)
  termsUrl             String?
  permissionReference  String?
  robotsCheckedAt      DateTime?
  termsCheckedAt       DateTime?
  renderMode           RenderMode            @default(HTTP)
  priceSelector        String?
  availabilitySelector String?
  requestsPerMinute    Int                   @default(6)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  matches ProductMatch[]

  @@index([active, legalStatus])
}

model ProductMatch {
  id              String             @id @default(cuid())
  variantId       String
  competitorId    String
  url             String
  status          ProductMatchStatus @default(PENDING)
  confidenceScore Int?
  internalNote    String?
  lastCheckedAt   DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  variant      ShopifyVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  competitor   Competitor         @relation(fields: [competitorId], references: [id], onDelete: Restrict)
  observations PriceObservation[]

  @@unique([variantId, url])
  @@index([competitorId, status])
  @@index([variantId, status])
}

model PriceObservation {
  id               String                 @id @default(cuid())
  matchId          String
  scrapeRunId      String?
  price            Decimal?               @db.Decimal(12, 2)
  currencyCode     String?                @db.VarChar(3)
  availability     String?
  extractionMethod PriceExtractionMethod?
  httpStatus       Int?
  errorCode        String?
  errorMessage     String?
  sourceHash       String?
  observedAt       DateTime               @default(now())
  createdAt        DateTime               @default(now())

  match     ProductMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scrapeRun ScrapeRun?   @relation(fields: [scrapeRunId], references: [id], onDelete: SetNull)

  @@index([matchId, observedAt(sort: Desc)])
  @@index([scrapeRunId])
}

model ScrapeRun {
  id         String          @id @default(cuid())
  trigger    ScrapeTrigger
  status     ScrapeRunStatus @default(RUNNING)
  total      Int             @default(0)
  succeeded  Int             @default(0)
  failed     Int             @default(0)
  startedAt  DateTime        @default(now())
  finishedAt DateTime?
  createdAt  DateTime        @default(now())

  observations PriceObservation[]

  @@index([startedAt(sort: Desc)])
}

model JobLock {
  id          String   @id
  token       String?
  lockedUntil DateTime @default(dbgenerated("'1970-01-01 00:00:00'::timestamp"))
  updatedAt   DateTime @updatedAt
}
