// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

enum CompetitorLegalStatus {
  PENDING
  APPROVED
  BLOCKED
}

enum RenderMode {
  HTTP
  BROWSER
}

enum ProductMatchStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum PriceExtractionMethod {
  JSON_LD
  META
  CSS
  FALLBACK
}

enum ScrapeRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum ScrapeTrigger {
  MANUAL
  CRON
}

enum RobotsAccessStatus {
  UNKNOWN
  ALLOWED
  DISALLOWED
}

model ShopifyProduct {
  id                    String    @id @default(cuid())
  shopifyId             String    @unique
  title                 String
  handle                String
  vendor                String?
  productType           String?
  categoryName          String?
  featuredImageUrl      String?
  featuredImageAlt      String?
  onlineStoreUrl        String?
  status                String
  firstVariantShopifyId String?
  firstVariantTitle     String?
  firstVariantSku       String?
  price                 Decimal   @default(0) @db.Decimal(12, 2)
  currencyCode          String    @default("EUR") @db.VarChar(3)
  shopifyCreatedAt      DateTime?
  shopifyUpdatedAt      DateTime?
  syncedAt              DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  matches ProductMatch[]

  @@index([vendor])
  @@index([status])
  @@index([title])
}

model Competitor {
  id                      String                @id @default(cuid())
  name                    String                @unique
  domain                  String                @unique
  active                  Boolean               @default(true)
  legalStatus             CompetitorLegalStatus @default(PENDING)
  termsUrl                String?
  permissionReference     String?
  robotsContent           String?
  robotsAccess            RobotsAccessStatus    @default(UNKNOWN)
  robotsOverrideConfirmed Boolean               @default(false)
  robotsCheckedAt         DateTime?
  termsCheckedAt          DateTime?
  renderMode              RenderMode            @default(HTTP)
  priceSelector           String?
  availabilitySelector    String?
  searchUrlTemplate       String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  matches      ProductMatch[]
  observations PriceObservation[]

  @@index([active, legalStatus])
}

model ProductMatch {
  id            String             @id @default(cuid())
  productId     String
  competitorId  String
  url           String
  searchQuery   String?
  status        ProductMatchStatus @default(PENDING)
  lastScrapedAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  product      ShopifyProduct     @relation(fields: [productId], references: [id], onDelete: Cascade)
  competitor   Competitor         @relation(fields: [competitorId], references: [id], onDelete: Restrict)
  observations PriceObservation[]

  @@unique([productId, url])
  @@index([competitorId, status])
  @@index([productId, status])
  @@index([lastScrapedAt])
}

model PriceObservation {
  id               String                 @id @default(cuid())
  matchId          String
  competitorId     String
  scrapeRunId      String?
  url              String
  price            Decimal?               @db.Decimal(12, 2)
  currencyCode     String?                @db.VarChar(3)
  availability     String?
  extractionMethod PriceExtractionMethod?
  httpStatus       Int?
  durationMs       Int                    @default(0)
  success          Boolean                @default(false)
  errorCode        String?
  errorMessage     String?
  sourceHash       String?
  observedAt       DateTime               @default(now())
  createdAt        DateTime               @default(now())

  match      ProductMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  competitor Competitor   @relation(fields: [competitorId], references: [id], onDelete: Restrict)
  scrapeRun  ScrapeRun?   @relation(fields: [scrapeRunId], references: [id], onDelete: SetNull)

  @@index([matchId, observedAt(sort: Desc)])
  @@index([competitorId, observedAt(sort: Desc)])
  @@index([scrapeRunId])
}

model ScrapeRun {
  id           String          @id @default(cuid())
  trigger      ScrapeTrigger
  status       ScrapeRunStatus @default(RUNNING)
  total        Int             @default(0)
  succeeded    Int             @default(0)
  failed       Int             @default(0)
  skipped      Int             @default(0)
  errorMessage String?
  startedAt    DateTime        @default(now())
  finishedAt   DateTime?
  createdAt    DateTime        @default(now())

  observations PriceObservation[]

  @@index([startedAt(sort: Desc)])
}

model AutomationSettings {
  id                   String    @id @default("default")
  enabled              Boolean   @default(true)
  intervalDays         Int       @default(5)
  nextRunAt            DateTime?
  lastSchedulerCheckAt DateTime?
  lastSchedulerStatus  String?
  lastSchedulerMessage String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model JobLock {
  id          String   @id
  token       String?
  lockedUntil DateTime @default(dbgenerated("'1970-01-01 00:00:00'::timestamp"))
  updatedAt   DateTime @updatedAt
}
